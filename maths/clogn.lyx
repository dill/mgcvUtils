\begin_layout Plain Layout

library(mgcv)
\end_layout

\begin_layout Plain Layout

library(mgcvUtils)
\end_layout

\begin_layout Plain Layout

library(ggplot2)
\end_layout

\begin_layout Plain Layout

\end_layout

\begin_layout Plain Layout

# make a 1D example with less noise
\end_layout

\begin_layout Plain Layout

set.seed(42)
\end_layout

\begin_layout Plain Layout

\end_layout

\begin_layout Plain Layout

# simulated example from ?gam
\end_layout

\begin_layout Plain Layout

dat <- gamSim(1,
 n=200,
 dist="normal",
 scale=1)
\end_layout

\begin_layout Plain Layout

\end_layout

\begin_layout Plain Layout

e <- rnorm(nrow(dat),
 sd=2)
\end_layout

\begin_layout Plain Layout

dat$y2 <- 10^(dat$f2/10 + e)
\end_layout

\begin_layout Plain Layout

\end_layout

\begin_layout Plain Layout

# censor values below some value
\end_layout

\begin_layout Plain Layout

dat$y2 <- cbind(dat$y2,
 dat$y2)
\end_layout

\begin_layout Plain Layout

# indicate which values are censored,
 see ?cnorm for rules
\end_layout

\begin_layout Plain Layout

dat$y2[dat$y2[,
 1] < 0.01,
 2] <- -Inf
\end_layout

\begin_layout Plain Layout

dat$y2[dat$y2[,
 1] < 0.01,
 1] <- 0.01
\end_layout

\begin_layout Plain Layout

\end_layout

\begin_layout Plain Layout

# response will be transformed by clognorm before fitting
\end_layout

\begin_layout Plain Layout

b2 <- gam(y2~s(x2),
 data=dat,
 method="REML",
 family=clognorm(base=10))
\end_layout

\begin_layout Plain Layout

summary(b2)
\end_layout

\begin_layout Plain Layout

\end_layout

\end_inset


\end_layout

