\begin_layout Plain Layout

# use a random subset of the data for clarity
\end_layout

\begin_layout Plain Layout

pred <- dat[sample(1:nrow(dat),
 50),
 ]
\end_layout

\begin_layout Plain Layout

# need to remove the response
\end_layout

\begin_layout Plain Layout

pred$y2 <- NULL
\end_layout

\begin_layout Plain Layout

\end_layout

\begin_layout Plain Layout

# uncorrected (on log10 scale)
\end_layout

\begin_layout Plain Layout

old <- predict(b2,
 newdata=pred,
 se=TRUE)
\end_layout

\begin_layout Plain Layout

# corrected (on response scale)
\end_layout

\begin_layout Plain Layout

new <- predict(b2,
 newdata=pred,
 type="response",
 se=TRUE)
\end_layout

\begin_layout Plain Layout

\end_layout

\begin_layout Plain Layout

# create data.frame for plotting
\end_layout

\begin_layout Plain Layout

preddat <- data.frame(pred.old = 10^old$fit,
\end_layout

\begin_layout Plain Layout

                      pred.cor = new$fit,
\end_layout

\begin_layout Plain Layout

                      pred.upper.old = 10^(old$fit + 1.96*old$se.fit),
\end_layout

\begin_layout Plain Layout

                      pred.upper.cor = 10^(log10(new$fit) + 1.96*new$se.fit),
\end_layout

\begin_layout Plain Layout

                      pred.lower.old = 10^(old$fit - 1.96*old$se.fit),
\end_layout

\begin_layout Plain Layout

                      pred.lower.cor = 10^(log10(new$fit) - 1.96*new$se.fit))
\end_layout

\begin_layout Plain Layout

\end_layout

\begin_layout Plain Layout

# pretty (ish) plot
\end_layout

\begin_layout Plain Layout

ggplot(preddat) +
\end_layout

\begin_layout Plain Layout

  geom_point(aes(x=pred.old,
 y=pred.cor)) +
\end_layout

\begin_layout Plain Layout

  geom_segment(aes(x=pred.lower.old,
 xend=pred.upper.old,
\end_layout

\begin_layout Plain Layout

                   y=pred.cor,
 yend=pred.cor)) +
\end_layout

\begin_layout Plain Layout

  geom_segment(aes(y=pred.lower.cor,
 yend=pred.upper.cor,
\end_layout

\begin_layout Plain Layout

                   x=pred.old,
